<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config for Sagar Android
    - Allows cleartext (HTTP) traffic to all domains (needed for some embed players)
    - Trusts all CA certificates (system + user) so player CDNs load properly
    - Required for: videasy, vidsrc, vidking embed players in Capacitor WebView
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <!-- Explicit HTTPS-only for TMDB API and image CDN -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.themoviedb.org</domain>
        <domain includeSubdomains="true">image.tmdb.org</domain>
        <domain includeSubdomains="true">firebase.google.com</domain>
        <domain includeSubdomains="true">firebaseapp.com</domain>
    </domain-config>
</network-security-config>
