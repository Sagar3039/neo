{
  "appId": "com.sagar.streaming",
  "appName": "Sagar",
  "webDir": "dist",
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": false
    }
  },
  "server": {
    "androidScheme": "https",
    "cleartext": true,
    "allowNavigation": [
      "*.videasy.net",
      "*.vsembed.su",
      "*.vidking.net",
      "*.allmanga.to",
      "*.themoviedb.org",
      "*.image.tmdb.org",
      "*.vidsrc.*",
      "*.2embed.*"
    ]
  }
}
